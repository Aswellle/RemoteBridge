# TLS-terminating reverse proxy for RemoteBridge (docker-compose service "caddy").
#
# - For a real deployment, set DOMAIN to your public hostname in .env; Caddy
#   will automatically obtain and renew a Let's Encrypt certificate for it.
# - For local testing, the default "localhost" makes Caddy serve HTTPS with
#   its internal (self-signed) CA - import Caddy's local root CA or accept
#   the browser warning.
#
# Routing:
#   /api/*  and /health  -> relay server REST API
#   /ws*               -> relay server WebSocket endpoint
#   everything else    -> Next.js web client

{$DOMAIN:localhost} {
	encode gzip

	# ===== 安全响应头（生产环境必备）=====
	header {
		# HSTS：一年内强制 HTTPS，含子域名，可提交至 preload list
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		# 禁止浏览器 MIME 类型嗅探
		X-Content-Type-Options "nosniff"
		# 禁止本站被嵌入到任何 iframe（兼容不支持 CSP frame-ancestors 的旧浏览器）
		X-Frame-Options "DENY"
		# 跨域请求只发送 origin，同域请求发送完整 referrer
		Referrer-Policy "strict-origin-when-cross-origin"
		# 关闭所有浏览器特性（摄像头/麦克风/地理位置等），按需开放
		Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"
		# 隐藏 Caddy 版本信息
		-Server
	}

	@server path /api/* /health /ws*
	handle @server {
		reverse_proxy server:3001
	}

	handle {
		reverse_proxy web:3000
	}
}
