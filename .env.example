# RemoteBridge 环境变量（apps/server 在启动时读取）

# ===== Relay Server =====
# 监听端口与地址。生产环境通常部署在反向代理之后，由代理终止 TLS；
# RELAY_PORT 本身不提供 TLS（见 README/CLAUDE.md 中关于反向代理的说明）。
RELAY_PORT=3002
RELAY_HOST=0.0.0.0

# JWT 签名密钥：access token 与 refresh token 必须使用两个独立的高强度随机字符串。
# 生成方式（各生成一次，分别填入下面两项）：
#   openssl rand -base64 48
# 当 NODE_ENV=production 时，若 JWT_SECRET / JWT_REFRESH_SECRET 缺失、为默认值、
# 长度不足、彼此相同、或 JWT_REFRESH_SECRET 由 JWT_SECRET 派生，服务器将拒绝启动。
JWT_SECRET=change-me-to-a-random-string
JWT_REFRESH_SECRET=change-me-to-another-random-string

# ===== 运行环境 =====
# 设为 production 以启用上述 JWT 密钥强度校验（推荐用于任何公网部署）
NODE_ENV=production

# ===== Database =====
# SQLite 数据目录（存放 remotebridge.db）。留空时默认为 ~/.remotebridge/data
RB_DATA_DIR=

# ===== CORS =====
# Web 客户端的来源(协议+域名,逗号分隔多个)。留空时回退为 http://localhost:3000——
# 生产环境务必显式设置为实际域名,否则部署后的 Web 客户端会被 CORS 拦截。
ALLOWED_ORIGINS=https://your-domain.com

# ===== Rate Limiting =====
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW=60000

# ===== Docker Compose (docker-compose.yml) =====
# 公开域名：Caddy 会自动为其申请/续期 Let's Encrypt 证书。
# 本地测试可保留默认值 localhost（Caddy 使用内置 CA 提供自签名 HTTPS）。
DOMAIN=localhost

# 构建 apps/web 镜像时写入客户端 bundle 的相对地址，需与上面的 DOMAIN 一致，
# 经由 Caddy 反向代理（/api/* 与 /ws* -> server，其余 -> web）。
NEXT_PUBLIC_API_URL=https://localhost/api/v1
NEXT_PUBLIC_WS_URL=wss://localhost/ws
